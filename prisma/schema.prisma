// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("USER") // USER or ADMIN
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Site Content for Home Page (backend-updatable)
model SiteContent {
  id        String   @id @default(cuid())
  section   String   @unique // "hero", "stats", "about", "venues", "cta"
  title     String?
  subtitle  String?
  content   Json     // Flexible JSON based on section
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Application Models
model Event {
  id           String   @id @default(cuid())
  name         String
  description  String
  category     String
  date         DateTime
  location     String
  venue        String
  image        String
  showtimes    String[]
  ticketTypes  Json     // Array of { type: string, price: number }
  seatingChart Json?    // Complex JSON structure for seating
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  bookings     Booking[]
  blockedSeats BlockedSeat[]
}

// Admin-managed blocked seats (unavailable for booking)
model BlockedSeat {
  id        String   @id @default(cuid())
  eventId   String
  seatId    String   // e.g. "MEM-A-1"
  reason    String?  // "maintenance", "vip-reserved", etc.
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, seatId])
}

model Member {
  id               String   @id @default(cuid())
  applicationId    Int
  memberId         Int      @unique
  categoryType     String
  categoryAcronym  String
  doa              DateTime
  name             String
  phone            String
  email            String
  dob              DateTime
  address          String
  emergencyContact String
  userId           String?  @unique // Linked website account
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Hall {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  sections    Json     // Array of { sectionName, rows: [{ rowId, seats, zone, blocked: number[] }] }
  totalSeats  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Booking {
  id          String    @id @default(cuid())
  userId      String
  eventId     String
  eventName   String
  eventDate   DateTime
  attendees   Json      // Array of Attendee objects
  total       Float
  bookingDate DateTime  @default(now())
  paymentInfo Json?     // { method: "phonepe"|"gpay"|"paytm"|"card"|"cash", upiTransactionId?: string, upiRefNo?: string, status: "pending"|"completed"|"failed" }
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  checkIns    CheckIn[]
}

// Fee configuration (singleton — only one active row)
model FeeConfig {
  id                String   @id @default(cuid())
  gstPercentage     Float    @default(18)
  platformFeeType   String   @default("PERCENTAGE") // "PERCENTAGE" | "FLAT"
  platformFeeValue  Float    @default(2.5)
  active            Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}

model CheckIn {
  id           String   @id @default(cuid())
  bookingId    String
  eventId      String
  seatId       String
  attendeeName String
  checkedInAt  DateTime @default(now())
  checkedBy    String?
  
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, seatId])
}
